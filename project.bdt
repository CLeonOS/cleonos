[project]
name = CLeonOS
default = iso
build_dir = .bdt
language = zh-CN
doctor_tools = {CC},{KERNEL_CXX},{USER_CXX},{LD},{RUSTC},{TAR},{XORRISO}

[subprojects]
paths = bdt, clks, cleonos

[cache]
path = {root}/{build_dir}/cache
archive = {root}/{build_dir}/bdt-cache.tar

[tools]
CC = gcc
KERNEL_CXX = g++
USER_CXX = g++
LD = ld
RUSTC = rustc
NM = nm
TAR = tar
XORRISO = xorriso
QEMU_X86_64 = qemu-system-x86_64
python = python3

[config]
KERNEL_CFLAGS = -std=c11,-ffreestanding,-fno-stack-protector,-fno-builtin,-U_FORTIFY_SOURCE,-D_FORTIFY_SOURCE=0,-g,-Wall,-Wextra,-Werror,-Wno-error=unused-variable,-Wno-error=unused-parameter,-Wno-error=unused-function,-I{root}/build/bdt-freestanding/include,-I{root}/clks/include,-include,{root}/build/bdt-menuconfig/clks_config.h,-m64,-mno-red-zone,-mcmodel=kernel,-fno-pic,-fno-pie,-fno-PIE
KERNEL_CXXFLAGS = -std=c++17,-ffreestanding,-fno-stack-protector,-fno-builtin,-U_FORTIFY_SOURCE,-D_FORTIFY_SOURCE=0,-fno-exceptions,-fno-rtti,-fno-threadsafe-statics,-fno-use-cxa-atexit,-g,-Wall,-Wextra,-Werror,-Wno-error=unused-variable,-Wno-error=unused-parameter,-Wno-error=unused-function,-I{root}/build/bdt-freestanding/include,-I{root}/clks/include,-include,{root}/build/bdt-menuconfig/clks_config.h,-m64,-mno-red-zone,-mcmodel=kernel,-fno-pic,-fno-pie,-fno-PIE
KERNEL_ASFLAGS = -ffreestanding,-I{root}/clks/include,-include,{root}/build/bdt-menuconfig/clks_config.h,-m64,-mno-red-zone,-mcmodel=kernel,-fno-pic,-fno-pie,-fno-PIE
KERNEL_LDFLAGS = -nostdlib,-z,max-page-size=0x1000
USER_CFLAGS = -std=c11,-ffreestanding,-fno-stack-protector,-fno-builtin,-Wall,-Wextra,-I{root}/cleonos/c/include,-I{root}/cleonos/c/apps
USER_CXXFLAGS = -std=c++17,-ffreestanding,-fno-stack-protector,-fno-builtin,-fno-exceptions,-fno-rtti,-fno-threadsafe-statics,-fno-use-cxa-atexit,-Wall,-Wextra,-I{root}/cleonos/c/include,-I{root}/cleonos/c/apps,-I{root}/cleonos/third-party/StardustUI,-I{root}/cleonos/third-party/StardustUI/includes,-DSTARDUSTUI_CLEONOS
USER_TLS_CFLAGS = -I{root}/cleonos/third-party/mbedtls/include,-DMBEDTLS_CONFIG_FILE='<tls/cleonos_mbedtls_config.h>',-DMBEDTLS_HAVE_INT32
USER_GUMBO_CFLAGS = -I{root}/cleonos/third-party/litehtml/src/gumbo/include,-I{root}/cleonos/third-party/litehtml/src/gumbo/include/gumbo,-I{root}/cleonos/third-party/litehtml/src/gumbo,-DNDEBUG
USER_DOOM_CFLAGS = -I{root}/cleonos/third-party/doomgeneric/doomgeneric,-I{root}/cleonos/c/apps/doom,-include,{root}/cleonos/c/apps/doom/doom_shim.h,-DNORMALUNIX,-D_DEFAULT_SOURCE
USER_LUA_CFLAGS = -I{root}/cleonos/c/apps/lua,-I{root}/cleonos/third-party/lua/src,-include,{root}/cleonos/c/apps/lua/lua_cleonos_config.h,-include,{root}/cleonos/c/apps/lua/lua_cleonos_compat.h
USER_ZLIB_CFLAGS = -I{root}/cleonos/third-party/zlib,-DHAVE_MEMCPY,-DNO_GZIP,-DNO_GZCOMPRESS
USER_MINIZIP_CFLAGS = {USER_ZLIB_CFLAGS},-I{root}/cleonos/third-party/zlib/contrib/minizip,-DNO_ERRNO_H,-DNOUNCRYPT
USER_LIBPNG_CFLAGS = -I{root}/cleonos/third-party/libpng,{USER_ZLIB_CFLAGS}
USER_CJSON_CFLAGS = -I{root}/cleonos/third-party/cJSON,-I{root}/cleonos/c/pkg,-include,{root}/cleonos/c/pkg/pkg_cjson_config.h,-mstackrealign
USER_STB_CFLAGS = -I{root}/cleonos/third-party/stb,-I{root}/cleonos/c/apps/stb,-mstackrealign,-Wno-unused-parameter
USER_TCC_CFLAGS = -I{root}/cleonos/c/apps/tcc,-I{root}/cleonos/third-party/tinycc,-I{root}/cleonos/third-party/tinycc/include,-include,{root}/cleonos/c/apps/tcc/tcc_cleonos_compat.h,-DTCC_TARGET_X86_64,-DCONFIG_TCC_STATIC,-DONE_SOURCE=1,-DNDEBUG,-U_WIN32,-U__x86_64__,-U__amd64__,-Wno-unused-parameter,-Wno-sign-compare,-Wno-missing-field-initializers,-Wno-implicit-fallthrough,-Wno-format,-Wno-return-type
USER_BDT_CFLAGS = -I{root}/cleonos/c/apps/bdt,-I{root}/bdt/src,-include,{root}/cleonos/c/apps/bdt/bdt_cleonos_compat.h,-DBDT_MAX_QUICK_MANIFESTS=64,-Wno-unused-parameter,-Wno-sign-compare
USER_TERMBOX2_CFLAGS = -I{root}/cleonos/c/include
USER_SQLITE_CFLAGS = -I{root}/cleonos/third-party/sqlite,-DSQLITE_OS_OTHER=1,-DSQLITE_THREADSAFE=0,-DSQLITE_OMIT_LOAD_EXTENSION=1,-DSQLITE_OMIT_WAL=1,-DSQLITE_TEMP_STORE=3,-DSQLITE_OMIT_SHARED_CACHE=1,-DSQLITE_OMIT_LOCALTIME=1,-DSQLITE_OMIT_UTF16=1,-DSQLITE_DEFAULT_MEMSTATUS=0
USER_TLS_SOURCES = {root}/cleonos/c/apps/tls/cleonos_tls.c,{root}/cleonos/c/apps/tls/cleonos_tls_entropy.c,{root}/cleonos/third-party/mbedtls/library/aes.c,{root}/cleonos/third-party/mbedtls/library/asn1parse.c,{root}/cleonos/third-party/mbedtls/library/asn1write.c,{root}/cleonos/third-party/mbedtls/library/bignum.c,{root}/cleonos/third-party/mbedtls/library/bignum_core.c,{root}/cleonos/third-party/mbedtls/library/bignum_mod.c,{root}/cleonos/third-party/mbedtls/library/bignum_mod_raw.c,{root}/cleonos/third-party/mbedtls/library/cipher.c,{root}/cleonos/third-party/mbedtls/library/cipher_wrap.c,{root}/cleonos/third-party/mbedtls/library/constant_time.c,{root}/cleonos/third-party/mbedtls/library/ctr_drbg.c,{root}/cleonos/third-party/mbedtls/library/ecdh.c,{root}/cleonos/third-party/mbedtls/library/ecdsa.c,{root}/cleonos/third-party/mbedtls/library/ecp.c,{root}/cleonos/third-party/mbedtls/library/ecp_curves.c,{root}/cleonos/third-party/mbedtls/library/entropy.c,{root}/cleonos/third-party/mbedtls/library/error.c,{root}/cleonos/third-party/mbedtls/library/gcm.c,{root}/cleonos/third-party/mbedtls/library/md.c,{root}/cleonos/third-party/mbedtls/library/oid.c,{root}/cleonos/third-party/mbedtls/library/pk.c,{root}/cleonos/third-party/mbedtls/library/pk_ecc.c,{root}/cleonos/third-party/mbedtls/library/pk_wrap.c,{root}/cleonos/third-party/mbedtls/library/pkparse.c,{root}/cleonos/third-party/mbedtls/library/platform.c,{root}/cleonos/third-party/mbedtls/library/platform_util.c,{root}/cleonos/third-party/mbedtls/library/rsa.c,{root}/cleonos/third-party/mbedtls/library/rsa_alt_helpers.c,{root}/cleonos/third-party/mbedtls/library/sha256.c,{root}/cleonos/third-party/mbedtls/library/sha512.c,{root}/cleonos/third-party/mbedtls/library/ssl_ciphersuites.c,{root}/cleonos/third-party/mbedtls/library/ssl_client.c,{root}/cleonos/third-party/mbedtls/library/ssl_msg.c,{root}/cleonos/third-party/mbedtls/library/ssl_tls.c,{root}/cleonos/third-party/mbedtls/library/ssl_tls12_client.c,{root}/cleonos/third-party/mbedtls/library/version_features.c,{root}/cleonos/third-party/mbedtls/library/x509.c,{root}/cleonos/third-party/mbedtls/library/x509_crt.c
USER_BDT_SOURCES = {root}/cleonos/c/apps/bdt/bdt_cleonos_compat.c,{root}/bdt/src/appbuilder.c,{root}/bdt/src/bench.c,{root}/bdt/src/cache.c,{root}/bdt/src/config.c,{root}/bdt/src/diagnostics.c,{root}/bdt/src/executor.c,{root}/bdt/src/graph.c,{root}/bdt/src/hash.c,{root}/bdt/src/lang.c,{root}/bdt/src/log.c,{root}/bdt/src/plugin.c,{root}/bdt/src/project.c,{root}/bdt/src/scanner.c,{root}/bdt/src/shared_cache.c,{root}/bdt/src/status.c,{root}/bdt/src/toolchain.c,{root}/bdt/src/trace.c,{root}/bdt/src/util.c,{root}/bdt/src/view.c
USER_SQLITE_SOURCES = {root}/cleonos/c/apps/sqlite/sqlite_cleonos_vfs.c,{root}/cleonos/third-party/sqlite/sqlite3.c
USER_LUA_SOURCES = {root}/cleonos/c/apps/lua/lua_cleonos_compat.c,{root}/cleonos/c/apps/lua/lua_cleonos_libs.c,{root}/cleonos/c/apps/lua/lua_cleonos_setjmp.c,{root}/cleonos/third-party/lua/src/lapi.c,{root}/cleonos/third-party/lua/src/lauxlib.c,{root}/cleonos/third-party/lua/src/lbaselib.c,{root}/cleonos/third-party/lua/src/lcode.c,{root}/cleonos/third-party/lua/src/lcorolib.c,{root}/cleonos/third-party/lua/src/lctype.c,{root}/cleonos/third-party/lua/src/ldblib.c,{root}/cleonos/third-party/lua/src/ldebug.c,{root}/cleonos/third-party/lua/src/ldo.c,{root}/cleonos/third-party/lua/src/ldump.c,{root}/cleonos/third-party/lua/src/lfunc.c,{root}/cleonos/third-party/lua/src/lgc.c,{root}/cleonos/third-party/lua/src/llex.c,{root}/cleonos/third-party/lua/src/lmem.c,{root}/cleonos/third-party/lua/src/lobject.c,{root}/cleonos/third-party/lua/src/lopcodes.c,{root}/cleonos/third-party/lua/src/lparser.c,{root}/cleonos/third-party/lua/src/lstate.c,{root}/cleonos/third-party/lua/src/lstring.c,{root}/cleonos/third-party/lua/src/lstrlib.c,{root}/cleonos/third-party/lua/src/ltable.c,{root}/cleonos/third-party/lua/src/ltablib.c,{root}/cleonos/third-party/lua/src/ltm.c,{root}/cleonos/third-party/lua/src/lundump.c,{root}/cleonos/third-party/lua/src/lutf8lib.c,{root}/cleonos/third-party/lua/src/lvm.c,{root}/cleonos/third-party/lua/src/lzio.c
USER_ZLIB_SOURCES = {root}/cleonos/third-party/zlib/adler32.c,{root}/cleonos/third-party/zlib/compress.c,{root}/cleonos/third-party/zlib/crc32.c,{root}/cleonos/third-party/zlib/deflate.c,{root}/cleonos/third-party/zlib/inffast.c,{root}/cleonos/third-party/zlib/inflate.c,{root}/cleonos/third-party/zlib/inftrees.c,{root}/cleonos/third-party/zlib/trees.c,{root}/cleonos/third-party/zlib/uncompr.c,{root}/cleonos/third-party/zlib/zutil.c
USER_MINIZIP_UNZIP_SOURCES = {root}/cleonos/c/apps/minizip_cleonos_io.c,{root}/cleonos/third-party/zlib/contrib/minizip/unzip.c
USER_MINIZIP_ZIP_SOURCES = {root}/cleonos/c/apps/minizip_cleonos_io.c,{root}/cleonos/c/apps/minizip_cleonos_time.c,{root}/cleonos/c/apps/minizip_cleonos_setjmp.c,{root}/cleonos/c/apps/minizip_cleonos_assert.c,{root}/cleonos/third-party/zlib/contrib/minizip/zip.c
USER_LIBPNG_SOURCES = {root}/cleonos/third-party/libpng/png.c,{root}/cleonos/third-party/libpng/pngerror.c,{root}/cleonos/third-party/libpng/pngget.c,{root}/cleonos/third-party/libpng/pngmem.c,{root}/cleonos/third-party/libpng/pngread.c,{root}/cleonos/third-party/libpng/pngrio.c,{root}/cleonos/third-party/libpng/pngrtran.c,{root}/cleonos/third-party/libpng/pngrutil.c,{root}/cleonos/third-party/libpng/pngset.c,{root}/cleonos/third-party/libpng/pngtrans.c
USER_CJSON_SOURCES = {root}/cleonos/third-party/cJSON/cJSON.c,{root}/cleonos/c/pkg/pkg_cjson_compat.c
USER_STB_SOURCES = {root}/cleonos/c/apps/stb/stb_image_cleonos.c
USER_STARDUSTUI_SOURCES = {root}/cleonos/c/src/cxx_runtime.cpp,{root}/cleonos/third-party/StardustUI/src/file.cpp,{root}/cleonos/third-party/StardustUI/src/window.cpp,{root}/cleonos/third-party/StardustUI/src/components/base.cpp,{root}/cleonos/third-party/StardustUI/src/components/button.cpp,{root}/cleonos/third-party/StardustUI/src/components/canvas.cpp,{root}/cleonos/third-party/StardustUI/src/components/flex.cpp,{root}/cleonos/third-party/StardustUI/src/components/lable.cpp,{root}/cleonos/third-party/StardustUI/src/components/scrollbar.cpp,{root}/cleonos/third-party/StardustUI/src/components/textbox.cpp,{root}/cleonos/third-party/StardustUI/src/platforms/cleonos.cpp
USER_LDFLAGS = -nostdlib,-z,max-page-size=0x1000,--gc-sections
DISK_IMAGE_MB = 128
DISK_IMAGE_BYTES = 134217728
menuconfig_args =
menuconfig_preset =

[target.configure]
type = group
steps = echo "bdt configure: no generator step required"
cache = false
always = true

[target.setup-tools]
type = group
steps = {CC} --version | {KERNEL_CXX} --version | {LD} --version | {RUSTC} --version
cache = false

[target.setup-freestanding-headers]
type = group
steps = mkdir -p "{root}/build/bdt-freestanding/include" | printf "#ifndef BDT_FREESTANDING_ASSERT_H\n#define BDT_FREESTANDING_ASSERT_H\n#ifdef NDEBUG\n#define assert(x) ((void)0)\n#else\n#define assert(x) ((void)((x) ? 0 : 0))\n#endif\n#endif\n" > "{root}/build/bdt-freestanding/include/assert.h"
cache = false

[target.menuconfig-headers]
type = command
command = {python} scripts/bdt_gen_menuconfig.py
cache = false

[target.setup-limine]
deps = setup-tools
type = command
command = if [ ! -f "{root}/limine/bootstrap" ] && [ ! -f "{root}/limine/configure" ]; then git submodule deinit -f limine || true; rm -rf "{root}/limine"; git submodule update --init --recursive --force limine; fi; if [ ! -f "{root}/limine/configure" ]; then (cd "{root}/limine" && ./bootstrap); fi; if [ ! -f "{root}/limine/GNUmakefile" ] && [ ! -f "{root}/limine/Makefile" ]; then (cd "{root}/limine" && CC={CC} CC_FOR_TARGET={CC} LD_FOR_TARGET={LD} OBJCOPY_FOR_TARGET=objcopy OBJDUMP_FOR_TARGET=objdump READELF_FOR_TARGET=readelf STRIP=strip ./configure --enable-bios --enable-bios-cd --enable-uefi-x86-64 --enable-uefi-cd); fi; make -C "{root}/limine"
cache = false

[target.setup]
deps = setup-tools, setup-freestanding-headers, setup-limine
type = group
steps = echo "setup complete"
cache = false

[target.kernel-objects]
deps = setup-freestanding-headers, menuconfig-headers
type = compile
tool = {CC}
sources = clks/kernel/boot/limine/limine_requests.c, clks/kernel/core/interrupts.c, clks/kernel/core/kmain.c, clks/kernel/core/log.c, clks/kernel/core/panic.c, clks/kernel/core/scheduler.c, clks/kernel/core/service.c, clks/kernel/hal/audio/pcspeaker.c, clks/kernel/hal/serial/serial.c, clks/kernel/hal/video/font8x8.c, clks/kernel/hal/video/framebuffer.c, clks/kernel/hal/video/psf_font.c, clks/kernel/input/inputm.c, clks/kernel/input/keyboard.c, clks/kernel/input/mouse.c, clks/kernel/interface/bootsplash.c, clks/kernel/interface/desktop.c, clks/kernel/interface/display.c, clks/kernel/interface/shell.c, clks/kernel/interface/tty.c, clks/kernel/interface/wm.c, clks/kernel/memory/heap.c, clks/kernel/memory/pmm.c, clks/kernel/memory/vm.c, clks/kernel/runtime/driver.c, clks/kernel/runtime/elf64.c, clks/kernel/runtime/elfrunner.c, clks/kernel/runtime/exec.c, clks/kernel/runtime/kelf.c, clks/kernel/runtime/locale.c, clks/kernel/runtime/net.c, clks/kernel/runtime/pty.c, clks/kernel/runtime/syscall.c, clks/kernel/runtime/user.c, clks/kernel/runtime/userland.c, clks/kernel/storage/disk.c, clks/kernel/storage/fs.c, clks/kernel/storage/ramdisk.c, clks/kernel/support/libc_compat.c, clks/kernel/support/string.c, clks/arch/x86_64/startup/boot.c, clks/third_party/miniz/miniz_support.c, clks/third_party/miniz/miniz_tdef.c, clks/third_party/qrcodegen/qrcodegen.c
output = {root}/build/x86_64/obj
cflags = {KERNEL_CFLAGS}
cache = true

[target.kernel-cpp-objects]
deps = setup-freestanding-headers, menuconfig-headers
type = compile
tool = {KERNEL_CXX}
sources = clks/kernel/core/panic_qr.cpp
output = {root}/build/x86_64/obj
cxxflags = {KERNEL_CXXFLAGS}
cache = true

[target.kernel-asm-objects]
deps = setup-freestanding-headers, menuconfig-headers
type = compile
tool = {CC}
sources = clks/arch/x86_64/interrupt/interrupt_stubs.S, clks/arch/x86_64/startup/exec_stack_call.S
output = {root}/build/x86_64/obj
asflags = {KERNEL_ASFLAGS}
cache = true

[target.kernel-rust]
type = rust-staticlib
sources = {root}/clks/rust/src/lib.rs
output = {root}/build/x86_64/libclks_kernel_rust.a
flags = --crate-type,staticlib,-C,panic=abort,-O
cache = false

[target.kernel]
deps = kernel-objects, kernel-cpp-objects, kernel-asm-objects, kernel-rust
type = link
tool = {LD}
inputs = {root}/build/x86_64/obj
objects = {root}/build/x86_64/libclks_kernel_rust.a
output = {root}/build/x86_64/clks_kernel.elf
linker_script = {root}/clks/arch/x86_64/linker.ld
ldflags = {KERNEL_LDFLAGS}
cache = true

[target.kernel-symbols]
deps = kernel
type = command
command = {NM} -n "{root}/build/x86_64/clks_kernel.elf" > "{root}/build/x86_64/kernel.sym"
cache = false

[target.user-rust]
type = rust-staticlib
sources = {root}/cleonos/rust/src/lib.rs
output = {root}/build/x86_64/user/lib/libcleonos_user_rust.a
flags = --crate-type,staticlib,-C,panic=abort,-O
cache = false

[target.tcc-runtime]
type = command
command = sh "{root}/scripts/build_tcc_runtime.sh" "{root}" "{CC}" ar
cache = false

[target.userapps]
deps = setup-tools
type = c-apps
tool = {CC}
cxxflags = {USER_CXXFLAGS}
main_dir = {root}/cleonos/c/apps
common_dirs = {root}/cleonos/c/src
runtime_sources = {root}/cleonos/c/apps/cmd_runtime.c, {root}/cleonos/c/apps/uwm_uilib/uwm_uilib.c
objects = {root}/build/x86_64/user/obj
output = {root}/build/x86_64/user/apps
entry_suffix = _main.c
secondary_entry_suffix = _kmain.c
secondary_output_group = system
runtime_exclude_apps = shell
output_group.default.output = {root}/build/x86_64/user/apps
output_group.driver.output = {root}/build/x86_64/user/apps/driver
output_group.driver.apps = ttydrv, serialdrv, fbdrv, pcspeakerdrv, diskdrv, netdrv, kbddrv, mousedrv
output_group.uwm.output = {root}/build/x86_64/user/apps/uwm
output_group.uwm.apps = file_explorer, terminal, taskmgr, pkg_gui, uwm_uilib, stardust_helloworld, stardust_layout
output_group.inputm.output = {root}/build/x86_64/user/apps/inputm
output_group.inputm.apps = pinyin, romaji, emoji, symbols
output_group.system.output = {root}/build/x86_64/user/system
output_group.system.linker_script = {root}/cleonos/c/kelf.ld
linker_script = {root}/cleonos/c/user.ld
cflags = {USER_CFLAGS}
ldflags = {USER_LDFLAGS}
app.shell.include_runtime = false
app.browser.cflags = {USER_TLS_CFLAGS},{USER_GUMBO_CFLAGS}
app.browser.sources = {USER_TLS_SOURCES}
app.browser.source_dirs = {root}/cleonos/third-party/litehtml/src/gumbo
app.httpget.cflags = {USER_TLS_CFLAGS}
app.httpget.sources = {USER_TLS_SOURCES}
app.wget.cflags = {USER_TLS_CFLAGS}
app.wget.sources = {USER_TLS_SOURCES}
app.lua.cflags = {USER_LUA_CFLAGS}
app.lua.sources = {USER_LUA_SOURCES}
app.zlibtest.cflags = {USER_ZLIB_CFLAGS}
app.zlibtest.sources = {USER_ZLIB_SOURCES}
app.unzip.cflags = {USER_MINIZIP_CFLAGS}
app.unzip.sources = {USER_MINIZIP_UNZIP_SOURCES},{USER_ZLIB_SOURCES}
app.zip.cflags = {USER_MINIZIP_CFLAGS}
app.zip.sources = {USER_MINIZIP_ZIP_SOURCES},{USER_ZLIB_SOURCES}
app.pngtest.cflags = {USER_LIBPNG_CFLAGS}
app.pngtest.sources = {USER_LIBPNG_SOURCES},{USER_ZLIB_SOURCES}
app.stbtest.cflags = {USER_STB_CFLAGS}
app.stbtest.sources = {USER_STB_SOURCES}
app.imgview.cflags = {USER_LIBPNG_CFLAGS},{USER_STB_CFLAGS}
app.imgview.sources = {USER_LIBPNG_SOURCES},{USER_ZLIB_SOURCES},{USER_STB_SOURCES}
app.tcc.cflags = {USER_TCC_CFLAGS}
app.tcc.sources = {root}/cleonos/c/apps/tcc/tcc_cleonos_compat.c,{root}/cleonos/c/apps/minizip_cleonos_setjmp.c
app.bdt.cflags = {USER_BDT_CFLAGS}
app.bdt.sources = {USER_BDT_SOURCES}
app.termbox2.cflags = {USER_TERMBOX2_CFLAGS}
app.termboxdemo.cflags = {USER_TERMBOX2_CFLAGS}
app.sqlitetest.cflags = {USER_SQLITE_CFLAGS}
app.sqlitetest.sources = {USER_SQLITE_SOURCES}
app.pkg.cflags = {USER_CJSON_CFLAGS},{USER_SQLITE_CFLAGS}
app.pkg.sources = {USER_CJSON_SOURCES},{USER_SQLITE_SOURCES},{root}/cleonos/c/pkg/pkg_state.c,{root}/cleonos/c/pkg/pkg_util.c,{root}/cleonos/c/pkg/pkg_json.c,{root}/cleonos/c/pkg/pkg_fs.c,{root}/cleonos/c/pkg/pkg_sha256.c,{root}/cleonos/c/pkg/pkg_manifest.c,{root}/cleonos/c/pkg/pkg_remote.c,{root}/cleonos/c/pkg/pkg_install.c,{root}/cleonos/c/pkg/pkg_check.c,{root}/cleonos/c/pkg/pkg_commands.c,{root}/cleonos/c/pkg/pkg_client.c,{root}/cleonos/c/pkg/pkg_sqlite.c
app.pkg_gui.cflags = {USER_CJSON_CFLAGS},{USER_SQLITE_CFLAGS}
app.pkg_gui.sources = {USER_CJSON_SOURCES},{USER_SQLITE_SOURCES},{root}/cleonos/c/pkg/pkg_state.c,{root}/cleonos/c/pkg/pkg_util.c,{root}/cleonos/c/pkg/pkg_json.c,{root}/cleonos/c/pkg/pkg_fs.c,{root}/cleonos/c/pkg/pkg_sha256.c,{root}/cleonos/c/pkg/pkg_manifest.c,{root}/cleonos/c/pkg/pkg_remote.c,{root}/cleonos/c/pkg/pkg_install.c,{root}/cleonos/c/pkg/pkg_check.c,{root}/cleonos/c/pkg/pkg_commands.c,{root}/cleonos/c/pkg/pkg_client.c,{root}/cleonos/c/pkg/pkg_sqlite.c
app.stardust_helloworld.sources = {USER_STARDUSTUI_SOURCES},{root}/cleonos/third-party/StardustUI/examples/helloworld/helloworld.cpp
app.stardust_helloworld.cflags = -DSTARDUSTUI_CLEONOS
app.stardust_layout.sources = {USER_STARDUSTUI_SOURCES},{root}/cleonos/third-party/StardustUI/examples/layout/layout.cpp
app.stardust_layout.cflags = -DSTARDUSTUI_CLEONOS
app.shell.sources = {root}/cleonos/c/apps/user/cleonos_user.c
app.install2disk.sources = {root}/cleonos/c/apps/user/cleonos_user.c
app.fastfetch.sources = {root}/cleonos/c/apps/user/cleonos_user.c
app.passwd.sources = {root}/cleonos/c/apps/user/cleonos_user.c
app.useradd.sources = {root}/cleonos/c/apps/user/cleonos_user.c
app.userdel.sources = {root}/cleonos/c/apps/user/cleonos_user.c
app.usermod.sources = {root}/cleonos/c/apps/user/cleonos_user.c
app.doom.cflags = {USER_DOOM_CFLAGS}
app.doom.source_dirs = {root}/cleonos/third-party/doomgeneric/doomgeneric
app.doom.exclude_sources = doomgeneric_allegro.c,doomgeneric_emscripten.c,doomgeneric_linuxvt.c,doomgeneric_sdl.c,doomgeneric_soso.c,doomgeneric_sosox.c,doomgeneric_win.c,doomgeneric_xlib.c,i_allegromusic.c,i_allegrosound.c,i_sdlmusic.c,i_sdlsound.c,icon.c
app.ttydrv.include_runtime = false
app.serialdrv.include_runtime = false
app.fbdrv.include_runtime = false
app.pcspeakerdrv.include_runtime = false
app.diskdrv.include_runtime = false
app.netdrv.include_runtime = false
app.kbddrv.include_runtime = false
app.mousedrv.include_runtime = false
cache = true

[target.ramdisk-root]
deps = userapps, tcc-runtime, kernel-symbols, setup-limine
type = group
steps = rm -rf "{root}/build/x86_64/ramdisk_root" | mkdir -p "{root}/build/x86_64/ramdisk_root" | cp -R "{root}/ramdisk/." "{root}/build/x86_64/ramdisk_root/" | mkdir -p "{root}/build/x86_64/ramdisk_root/system" "{root}/build/x86_64/ramdisk_root/system/install" "{root}/build/x86_64/ramdisk_root/system/tcc" "{root}/build/x86_64/ramdisk_root/shell" "{root}/build/x86_64/ramdisk_root/shell/uwm" "{root}/build/x86_64/ramdisk_root/shell/inputm" "{root}/build/x86_64/ramdisk_root/driver" | cp -R "{root}/build/x86_64/tccroot/." "{root}/build/x86_64/ramdisk_root/system/tcc/" | cp "{root}/build/x86_64/kernel.sym" "{root}/build/x86_64/ramdisk_root/system/kernel.sym" | cp "{root}/build/x86_64/clks_kernel.elf" "{root}/build/x86_64/ramdisk_root/system/install/clks_kernel.elf" | cp "{root}/limine/bin/limine-bios-hdd.bin" "{root}/build/x86_64/ramdisk_root/system/install/limine-bios-hdd.bin" | cp "{root}/limine/bin/limine-bios.sys" "{root}/build/x86_64/ramdisk_root/system/install/limine-bios.sys" | cp "{root}/configs/limine-harddisk.conf" "{root}/build/x86_64/ramdisk_root/system/install/limine-harddisk.conf" | cp "{root}/build/x86_64/user/apps/"*.elf "{root}/build/x86_64/ramdisk_root/shell/" | cp "{root}/build/x86_64/user/apps/uwm/"*.elf "{root}/build/x86_64/ramdisk_root/shell/uwm/" | cp "{root}/build/x86_64/user/apps/inputm/"*.elf "{root}/build/x86_64/ramdisk_root/shell/inputm/" | cp "{root}/build/x86_64/user/apps/driver/"*.elf "{root}/build/x86_64/ramdisk_root/driver/" | cp "{root}/build/x86_64/user/system/"*.elf "{root}/build/x86_64/ramdisk_root/system/"
cache = false

[target.ramdisk]
deps = ramdisk-root
type = tar
tool = {TAR}
inputs = {root}/build/x86_64/ramdisk_root
output = {root}/build/x86_64/cleonos_ramdisk.tar
cache = false

[target.disk-image]
type = truncate
output = {root}/build/x86_64/cleonos_disk.img
flags = {DISK_IMAGE_MB}
cache = false

[target.iso]
deps = setup-limine, kernel, ramdisk
type = group
steps = rm -rf "{root}/build/x86_64/iso_root" | mkdir -p "{root}/build/x86_64/iso_root/boot/limine" "{root}/build/x86_64/iso_root/EFI/BOOT" | cp "{root}/build/x86_64/clks_kernel.elf" "{root}/build/x86_64/iso_root/boot/clks_kernel.elf" | cp "{root}/build/x86_64/cleonos_ramdisk.tar" "{root}/build/x86_64/iso_root/boot/cleonos_ramdisk.tar" | cp "{root}/configs/limine.conf" "{root}/build/x86_64/iso_root/boot/limine/limine.conf" | cp "{root}/configs/limine.conf" "{root}/build/x86_64/iso_root/limine.conf" | cp "{root}/limine/bin/limine-bios.sys" "{root}/build/x86_64/iso_root/boot/limine/limine-bios.sys" | cp "{root}/limine/bin/limine-bios-cd.bin" "{root}/build/x86_64/iso_root/boot/limine/limine-bios-cd.bin" | cp "{root}/limine/bin/limine-uefi-cd.bin" "{root}/build/x86_64/iso_root/boot/limine/limine-uefi-cd.bin" | cp "{root}/limine/bin/BOOTX64.EFI" "{root}/build/x86_64/iso_root/EFI/BOOT/BOOTX64.EFI" | {XORRISO} -as mkisofs -b boot/limine/limine-bios-cd.bin -no-emul-boot -boot-load-size 4 -boot-info-table --efi-boot boot/limine/limine-uefi-cd.bin -efi-boot-part --efi-boot-image --protective-msdos-label "{root}/build/x86_64/iso_root" -o "{root}/build/CLeonOS-x86_64.iso" | "{root}/limine/bin/limine" bios-install "{root}/build/CLeonOS-x86_64.iso"
cache = false

[target.run]
deps = iso, disk-image
type = command
command = {QEMU_X86_64} -M pc -m 1024M -boot order=d -cdrom "{root}/build/CLeonOS-x86_64.iso" -drive "file={root}/build/x86_64/cleonos_disk.img,format=raw,if=none,id=clksdisk,media=disk" -device "ide-hd,drive=clksdisk,bus=ide.0" -netdev "user,id=clksnet0" -device "e1000,netdev=clksnet0" -serial stdio
cache = false
always = true

[target.run-hardboot]
type = command
command = if [ ! -f "{root}/build/x86_64/cleonos_disk.img" ]; then echo "run-hardboot: missing build/x86_64/cleonos_disk.img; run make run and execute install2disk first"; exit 1; fi; {QEMU_X86_64} -M pc -m 1024M -boot order=c -drive "file={root}/build/x86_64/cleonos_disk.img,format=raw,if=none,id=clksdisk,media=disk" -device "ide-hd,drive=clksdisk,bus=ide.0" -netdev "user,id=clksnet0" -device "e1000,netdev=clksnet0" -serial stdio
cache = false
always = true

[target.debug]
deps = iso, disk-image
type = command
command = {QEMU_X86_64} -M pc -m 1024M -boot order=d -cdrom "{root}/build/CLeonOS-x86_64.iso" -drive "file={root}/build/x86_64/cleonos_disk.img,format=raw,if=none,id=clksdisk,media=disk" -device "ide-hd,drive=clksdisk,bus=ide.0" -netdev "user,id=clksnet0" -device "e1000,netdev=clksnet0" -serial stdio -s -S
cache = false
always = true

[target.menuconfig]
type = command
command = {python} scripts/menuconfig.py {menuconfig_preset} {menuconfig_args}
cache = false
always = true

[target.menuconfig-gui]
type = command
command = {python} scripts/menuconfig.py --gui {menuconfig_preset} {menuconfig_args}
cache = false
always = true

[target.clean-drive-image]
type = remove
inputs = {root}/build/x86_64/cleonos_disk.img
cache = false
always = true

[target.clean]
type = remove
inputs = {root}/build/x86_64
cache = false
always = true

[target.clean-all]
type = remove
inputs = {root}/build
cache = false
always = true

[target.help]
type = command
command = echo "use: bdt --list, bdt --scan, bdt --graph, bdt <target>"
cache = false
always = true
